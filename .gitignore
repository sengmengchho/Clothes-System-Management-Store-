# Root .gitignore for Django (backend) + Vite/React (frontend)

# ---------------- Python ----------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
pip-wheel-metadata/

# ---------------- Django ----------------
# SQLite database (if used)
db.sqlite3
backend/db.sqlite3

# Media (user-uploaded files)
backend/media/
media/

# Django staticfiles (if you collect to a folder)
staticfiles/
static/

# Local settings and logs
local_settings.py
*.log

# Translation files
*.pot

# ---------------- Environment / Secrets ----------------
.env
.env.*
secrets.env
*.pem

# ---------------- Frontend (Node / Vite / React) ----------------
node_modules/
frontend/node_modules/
dist/
frontend/dist/
build/

# Keep lockfiles committed (package-lock.json, yarn.lock, pnpm-lock.yaml)
# do NOT ignore them unless you know what you're doing

# NPM/Yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------- IDEs / Editors ----------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---------------- OS ----------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------- Tests / Coverage ----------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ---------------- Jupyter ----------------
.ipynb_checkpoints/

# ---------------- Misc ----------------
*.egg
*.egg-info/
*.whl
*.so

# Windows thumbnail cache
ehthumbs.db
